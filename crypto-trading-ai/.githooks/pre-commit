#!/usr/bin/env bash
set -euo pipefail

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${HOOK_DIR}/.." && pwd)"
REPO_ROOT="$(git -C "${PROJECT_ROOT}" rev-parse --show-toplevel)"
cd "${PROJECT_ROOT}"

STAGED_FILES="$(git -C "${REPO_ROOT}" diff --cached --name-only --diff-filter=ACMR)"
CHECK_WORKFLOWS=0
CHECK_BACKEND=0
CHECK_FRONTEND=0

while IFS= read -r path; do
  [[ -z "${path}" ]] && continue
  case "${path}" in
    .github/workflows/*|crypto-trading-ai/.github/workflows/*|crypto-trading-ai/infra/github/workflows/*|crypto-trading-ai/scripts/check_github_workflows_sync.sh|crypto-trading-ai/scripts/sync_github_workflows.sh)
      CHECK_WORKFLOWS=1
      ;;
  esac
  case "${path}" in
    crypto-trading-ai/backend/*|crypto-trading-ai/shared/openapi/*|crypto-trading-ai/scripts/generate_shared_openapi.py|crypto-trading-ai/scripts/check_openapi_sync.py)
      CHECK_BACKEND=1
      ;;
  esac
  case "${path}" in
    crypto-trading-ai/frontend/*)
      CHECK_FRONTEND=1
      ;;
  esac
done <<< "${STAGED_FILES}"

if [[ ${CHECK_WORKFLOWS} -eq 0 && ${CHECK_BACKEND} -eq 0 && ${CHECK_FRONTEND} -eq 0 ]]; then
  echo "[pre-commit] No staged crypto-trading-ai files require service checks."
  exit 0
fi

if [[ ${CHECK_WORKFLOWS} -eq 1 ]]; then
  echo "[pre-commit] Checking workflow sync..."
  bash scripts/check_github_workflows_sync.sh
fi

if [[ ${CHECK_BACKEND} -eq 1 ]]; then
  echo "[pre-commit] Checking generated OpenAPI sync..."
  docker compose exec -T backend python /app/scripts/generate_shared_openapi.py --check >/dev/null

  echo "[pre-commit] Checking OpenAPI/route contracts..."
  docker compose exec -T backend python /app/scripts/check_openapi_sync.py >/dev/null

  echo "[pre-commit] Running backend lint..."
  docker compose exec -T backend ruff check /app/backend >/dev/null
fi

if [[ ${CHECK_FRONTEND} -eq 1 ]]; then
  echo "[pre-commit] Running frontend lint..."
  docker compose exec -T frontend sh -lc "cd /app/frontend && pnpm lint" >/dev/null
fi

echo "[pre-commit] Checks passed."
