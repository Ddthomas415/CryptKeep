# Core
ENVIRONMENT=dev
LOG_LEVEL=INFO
NO_TRADING=true

# Data stores
DATABASE_URL=postgresql://copilot:copilot@timescaledb:5432/copilot
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=documents
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=raw-docs

# Service endpoints
AUDIT_SERVICE_URL=http://audit-log:8009
ORCHESTRATOR_URL=http://orchestrator:8002
MEMORY_SERVICE_URL=http://memory-retrieval:8007
PARSER_SERVICE_URL=http://parser-normalizer:8006
RISK_SERVICE_URL=http://risk-stub:8008

# Market ingestion
EXCHANGE_ID=binance
EXCHANGE_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
MARKET_REST_POLL_SECONDS=10
MARKET_WS_ENABLED=true

# News ingestion
NEWS_RSS_URLS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://cointelegraph.com/rss
NEWS_POLL_SECONDS=180

# Archive
ARCHIVE_MAX_SNAPSHOTS=3

# HTTP
REQUEST_TIMEOUT_SECONDS=15
