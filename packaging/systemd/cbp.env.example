# CryptKeep operator environment for systemd units.
# Copy to /etc/cbp/cbp.env, review every value, and chmod 640 root:cbp.
#
# DELIBERATELY ABSENT: CBP_EXECUTION_ARMED and any live-enable state.
# Live trading authority flows ONLY through the one-time-token ceremony
# and system state; process supervision must never arm trading. Do not
# add arming variables to this file or to any unit.

# Canonical state directory (must match ReadWritePaths in the units)
CBP_STATE_DIR=/var/lib/cbp/state

# Unbuffered logs into journald
PYTHONUNBUFFERED=1

# Venue credentials are read by the exchange layer from its configured
# source; if your setup injects them via environment, add them here and
# keep this file root-owned and mode 640.
# COINBASE_API_KEY=
# COINBASE_API_SECRET=
