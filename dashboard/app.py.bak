import streamlit as st
# dashboard/app.py
import os
import sqlite3
import streamlit as st
import yaml as _yaml

# ---- Page Setup ----
st.set_page_config(page_title="Crypto Bot Pro", layout="wide")
st.title("Crypto Bot Pro")
mode = os.environ.get("CBP_MODE", "dev")
st.caption(f"Mode: {mode} | Phase 43: Canonical PnL + Safety + Service Control")

# ---- Quick Start & Feeds ----
col1, col2 = st.columns(2)
with col1:
    st.subheader("Quick start")
    st.code("python3 scripts/install.py\n./run_collector.sh\n./run_dashboard.sh", language="bash")
with col2:
    st.subheader("Feeds")
    st.write("Set env vars to control symbols:")
    st.code(
        "CBP_BINANCE_SYMBOLS=btcusdt,ethusdt\n"
        "CBP_COINBASE_PRODUCTS=BTC-USD,ETH-USD\n"
        "CBP_GATEIO_PAIRS=BTC_USDT,ETH_USDT\n"
        "CBP_CHANNELS=trades,book_l2\n"
        "CBP_FEEDS=binance,coinbase,gateio",
        language="text",
    )

st.divider()
st.divider()
st.header("Fill reconciler (delayed fills)")
st.caption("Service: fill_reconciler. Polls CCXT fetch_my_trades to catch fills that arrive after order placement. Requires authenticated keys for that venue.")
try:
    import yaml as _yaml
    cfg_path = os.path.join("runtime","config","user.yaml")
    cfg = _yaml.safe_load(open(cfg_path, "r", encoding="utf-8").read()) if os.path.exists(cfg_path) else {}
    cfg = cfg or {}
    st.json(cfg.get("recon", {}))
except Exception as e:
    st.error(f"Recon config read failed: {type(e).__name__}: {e}")
st.caption("Start it via Stack presets (live) or per-service Start -> fill_reconciler.")

# ---- Canonical PnL Panel ----
st.header("Canonical PnL (data/pnl.sqlite)")
st.caption("Deterministic realized PnL computed from recorded fills (avg-cost net position). Safety gates use this PnL for max_daily_loss.")
try:
    from storage.pnl_store_sqlite import PnLStoreSQLite
    ps = PnLStoreSQLite()
    st.subheader("Today realized PnL")
    st.json(ps.get_today_realized())
    st.subheader("Open positions")
    st.dataframe(ps.positions(), use_container_width=True, height=220)
    st.subheader("Last fills")
    st.dataframe(ps.last_fills(50), use_container_width=True, height=220)
except Exception as e:
    st.error(f"PnL panel failed: {type(e).__name__}: {e}")

# ---- Load Safety Config ----
cfg_path = os.path.join("runtime", "config", "user.yaml")
os.makedirs(os.path.dirname(cfg_path), exist_ok=True)
try:
    cfg = _yaml.safe_load(open(cfg_path, "r", encoding="utf-8").read()) if os.path.exists(cfg_path) else {}
    cfg = cfg or {}
except Exception:
    cfg = {}

safety_cfg = cfg.get("safety") if isinstance(cfg.get("safety"), dict) else {}
min_notional = float(safety_cfg.get("min_order_notional", 0.0))
max_trades = int(safety_cfg.get("max_trades_per_day", 0))
max_loss = float(safety_cfg.get("max_daily_loss", 0.0))
prefer_journal = bool(safety_cfg.get("prefer_journal_pnl", True))

# ---- Safety Gates Panel ----
st.header("Execution Safety Gates")
st.caption("Enforced in executors. Router annotates decisions with safety_ok/safety_reason.")
c1, c2, c3 = st.columns(3)

    try:
        cfg["safety"] = {
            "min_order_notional": float(min_notional_new),
            "max_trades_per_day": int(max_trades_new),
            "max_daily_loss": float(max_loss_new),
            "prefer_journal_pnl": bool(prefer_journal_new),
        }
        with open(cfg_path, "w", encoding="utf-8") as f:
            f.write(_yaml.safe_dump(cfg, sort_keys=False))
        st.success("Saved safety gates into runtime/config/user.yaml")
    except Exception as e:
        st.error(f"Save failed: {type(e).__name__}: {e}")

# ---- Paper Latency ----
st.subheader("Paper Latency Simulation")
execution_cfg = cfg.get("execution") if isinstance(cfg.get("execution"), dict) else {}
lat = execution_cfg.get("paper_latency_ms", [0, 0])
lat_a = int(lat[0]) if len(lat) > 0 else 0
lat_b = int(lat[1]) if len(lat) > 1 else 0
lc1, lc2 = st.columns(2)

    try:
        cfg.setdefault("execution", {})
        cfg["execution"]["paper_latency_ms"] = [int(lat_a_new), int(max(lat_a_new, lat_b_new))]
        with open(cfg_path, "w", encoding="utf-8") as f:
            f.write(_yaml.safe_dump(cfg, sort_keys=False))
        st.success("Saved execution.paper_latency_ms")
    except Exception as e:
        st.error(f"Save failed: {type(e).__name__}: {e}")

# ---- Today’s Safety State ----
st.subheader("Today’s Safety State (deterministic)")
try:
    from storage.execution_guard_store_sqlite import ExecutionGuardStoreSQLite
    from services.execution.safety import current_day_state
    st.json(current_day_state(ExecutionGuardStoreSQLite()))
except Exception as e:
    st.error(f"State read failed: {type(e).__name__}: {e}")

# ---- Latest Events ----
st.subheader("Latest Events (SQLite)")
events_db = os.path.join("data", "events.sqlite")
if not os.path.exists(events_db):
    st.warning("No events DB yet. Run the collector first: ./run_collector.sh")
else:
    try:
        conn = sqlite3.connect(events_db)
        cur = conn.execute("SELECT id, ts, venue, symbol, event_type FROM events ORDER BY id DESC LIMIT 50")
        rows = cur.fetchall()
        conn.close()
        st.dataframe(
            [{"id": r[0], "ts": r[1], "venue": r[2], "symbol": r[3], "type": r[4]} for r in rows],
            use_container_width=True,
        )
    except Exception as e:
        st.error(f"Failed to read DB: {e}")

# ---- Service Control ----
st.subheader("Service Control (Desktop)")
try:
    from desktop.service_manager import specs_default, start_service, stop_service, is_running
    specs = specs_default()
    cols = st.columns(4)
    names = list(specs.keys())
    for i, name in enumerate(names):
        with cols[i % 4]:
            running, msg = is_running(name)
            st.write(f"**{name}**")
            st.caption(f"{'RUNNING' if running else 'STOPPED'} • {msg}")
                ok, m = start_service(specs[name])
                st.toast(f"{name}: {m}")
                ok, m = stop_service(name)
                st.toast(f"{name}: {m}")
    st.caption("Logs + pid files are stored under: <runtime>/logs/")
except Exception as e:
    st.error(f"Service Control unavailable: {type(e).__name__}: {e}")

# ---- Logging Controls ----
st.subheader("Logging Controls")
st.caption("Log level is applied on next service start. Logs can be rotated anytime.")
try:
    from desktop.logging_control import set_log_level, set_log_rotate_bytes, rotate_logs
    c1, c2, c3 = st.columns(3)
        try:
            set_log_level(lvl)
            set_log_rotate_bytes(int(rot))
            st.success("Saved to runtime/config/user.yaml -> ops.*")
        except Exception as e:
            st.error(f"Save failed: {type(e).__name__}")
        st.json(rotate_logs())
        try:
            total = sum(os.path.getsize(os.path.join(root, f))
                        for root, _, files in os.walk(os.path.join("data","logs"))
                        for f in files)
            st.write({"data/logs_bytes": total})
        except Exception as e:
            st.error(f"Size calc failed: {e}")
except Exception as e:
    st.error(f"Logging controls unavailable: {type(e).__name__}")

# ---- Panic Button ----
st.subheader("PANIC")
st.caption("Stops ONLY execution services (paper/live). Data + feature services remain running.")
    try:
        from desktop.panic import panic_stop_execution
        st.json(panic_stop_execution())
    except Exception as e:
        st.error(f"Panic failed: {type(e).__name__}: {e}")
